{
  "manifest_version": 3,
  "name": "CacheCleaner",
  "version": "1.0",
  "description": "CacheCleaner is a browser plugin designed to efficiently clear your browser's cache, cookies, localStorage, and session data with a single click. Includes advanced settings to protect specific data.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon128.png",
    "default_title": "Clean Cache and Data"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "cookies",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
